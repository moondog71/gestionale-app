# Database
POSTGRES_DB=gestionale
POSTGRES_USER=gestionale_user
POSTGRES_PASSWORD=CAMBIA_QUESTO

# DATABASE_URL — la password va URL-encoded (es. ? diventa %3F)
DATABASE_URL=postgresql://gestionale_user:CAMBIA_QUESTO@postgres:5432/gestionale

# JWT — genera con: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# Credenziali app (single user)
APP_USERNAME=andrea
APP_PASSWORD_HASH=

# Google APIs — stesse credenziali di dossier-app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ID cartella "Gestionale" su Google Drive
GESTIONALE_DRIVE_FOLDER_ID=

# Email SMTP (App Password Gmail)
SMTP_USER=bombanaelettrodomestici@gmail.com
SMTP_PASS=
